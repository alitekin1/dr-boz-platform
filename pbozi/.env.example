# ──────────────────────────────────────────────────────────────
# BOZ GPT (JGPTi) — environment variables
# Copy to backend/.env and fill in real values
# ──────────────────────────────────────────────────────────────

# Bot token (from @botfather in Bale or Telegram)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
BOT_PLATFORM=bale
BALE_API_BASE_URL=https://tapi.bale.ai/
BALE_FILE_BASE_URL=https://tapi.bale.ai/file/
BALE_WALLET_PROVIDER_TOKEN=

# Transactions bot (separate bot for payment approvals)
TRANSACTIONS_BOT_TOKEN=
TRANSACTIONS_BOT_ADMIN_CHAT_ID=0
TRANSACTIONS_BOT_PLATFORM=bale

# Database & storage
DATABASE_URL=sqlite+aiosqlite:///./jgpti.db
CHROMA_PERSIST_DIR=./chroma_data
REDIS_URL=redis://127.0.0.1:6379/0

# Admin
ADMIN_PASSWORD=admin123

# Web search
WEB_SEARCH_PROVIDER=exa
WEB_SEARCH_API_URL=https://api.exa.ai/search
WEB_SEARCH_API_KEY=
WEB_SEARCH_MODEL=

# OpenRouter (for AI models)
OPENROUTER_API_KEY=

# Backup (disabled by default)
BACKUP_ENABLED=false
BACKUP_INTERVAL_MINUTES=5
BACKUP_MAX_COUNT=6
BACKUP_GOOGLE_DRIVE_FOLDER_ID=
BACKUP_GOOGLE_SERVICE_ACCOUNT_JSON=

# OpenWebUI sync
OPENWEBUI_URL=http://localhost:3000
OPENWEBUI_SYNC_SECRET=
